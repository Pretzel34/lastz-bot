{
  "name": "Use Shield from Warehouse",
  "actions": [
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_warehouse.png",
      "required": false
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "tap_template_from_setting",
      "setting": "shield.shield_type",
      "map": {
        "8hr shield": "btn_8_hr_shield.png",
        "24hr shield": "btn_24_hr_shield.png"
      },
      "max_scrolls": 1,
      "wait_seconds": 4.0,
      "required": false,
      "set_flag": "shield_found",
      "note": "Tap the shield type selected in farm settings; if not visible, scroll down, wait 4s, and look again. Flags whether a shield was found in the warehouse."
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_use_shield.png",
      "set_flag": "shield_applied",
      "log_success": "Shield applied",
      "log_skip": "Use button not found — shield not applied",
      "required": false
    },
    {
      "action": "record_shield_applied",
      "if_flag": "shield_applied",
      "note": "Persist the expiry (8h/24h per farm settings) so skip_if_shield_active blocks re-shielding while it is up"
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "tap_template_or_template",
      "template": "btn_back_out_of_page.png",
      "fallback_template": "btn_press_back.png",
      "required": false
    },
    {
      "action": "wait",
      "seconds": 4.0
    }
  ]
}
