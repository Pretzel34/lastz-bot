{
  "name": "start_rally_on_boomer",
  "actions": [
    {
      "action": "rally_count_check",
      "note": "Abort if daily rally limit already reached"
    },
    {
      "action": "ensure_hq_view",
      "hq_btn": "btn_go_world.png",
      "world_btn": "btn_go_headquarters.png",
      "note": "Guarantee a known starting state — returns to HQ if in world, no-ops if already in HQ"
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_go_world.png",
      "required": false,
      "note": "Navigate from HQ to world view — skip if already in world"
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "check_formations_busy",
      "slots": [
        {"x_pct": 92.6, "y_pct": 51.0},
        {"x_pct": 92.8, "y_pct": 56.9},
        {"x_pct": 92.6, "y_pct": 62.5},
        {"x_pct": 92.8, "y_pct": 68.0}
      ],
      "locked_template": "btn_fourth_formation_locked.png",
      "note": "Abort early if all formation slots are already occupied — no point searching for a boomer"
    },
    {
      "action": "tap_template_or_zone",
      "template": "btn_search_lens_icon.png",
      "x_pct": 5.2,
      "y_pct": 80.7,
      "required": false
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_boomer.png",
      "fallback_template": "btn_frostbane_boomer.png",
      "skip_task_if_not_found": true,
      "log_skip": "Boomer search panel not found — wrong screen, cancelling task",
      "note": "Select Boomer category. If neither template is visible the search panel didn't open — abort rather than continue on the wrong screen."
    },
    {
      "action": "wait",
      "seconds": 3.0
    },
    {
      "action": "adjust_boomer_level",
      "setting": "rally.boomer_level",
      "template_pattern": "btn_lvl_{value}_boomer.png",
      "plus_template": "btn_plus_boomer.png",
      "minus_template": "btn_subtract_boomer_lvl.png",
      "min_level": 1,
      "max_level": 47,
      "max_attempts": 50,
      "tap_delay": 3.0,
      "required": false,
      "note": "Detect current boomer level and tap +/- until it matches rally.boomer_level setting"
    },
    {
      "action": "wait",
      "seconds": 2.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_search_boomer.png",
      "required": false,
      "note": "Search with the correct level now set"
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_team_up_boomer.png",
      "fallback_template": "btn_team_up_boomer_alt.png",
      "required": true
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_march_on_boomer.png",
      "fallback_template": "btn_march_on_boomer_alt.png",
      "fuel_template": "btn_out_of_fuel.png",
      "required": false,
      "exhaust_rallies_if_not_found": true,
      "log_skip": "March not available — troops are busy, skipping rally attempt",
      "note": "If out of fuel, restore_fuel runs automatically and retries. If march still absent, troops are busy — abort."
    },
    {
      "action": "rally_count_record",
      "note": "Only reached when march was successfully tapped — record the rally now"
    },
    {
      "action": "wait",
      "seconds": 6.0
    }
  ]
}
