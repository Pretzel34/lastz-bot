{
  "name": "healing",
  "actions": [
    {
      "action": "ensure_hq_view",
      "hq_btn": "btn_go_world.png",
      "world_btn": "btn_go_headquarters.png"
    },
    {
      "action": "wait",
      "seconds": 2.0
    },
    {
      "action": "tap_template_or_template",
      "template": "btn_go_to_world_view.png",
      "fallback_template": "btn_go_world.png",
      "required": false
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "tap_first_found",
      "templates": [
        "btn_healed_troops_collect.png",
        "btn_collect_healed_2.png",
        "btn_collect_healed_3.png"
      ],
      "required": false,
      "log_skip": "No healed troops to collect"
    },
    {
      "action": "wait",
      "seconds": 2.0
    },
    {
      "action": "if_template_found",
      "template": "btn_heal_icon_alt.png",
      "log_found": "Troops currently healing — skipping to end",
      "log_skip": "No active heal in progress — continuing",
      "on_found": [
        {
          "action": "tap_template_or_template",
          "template": "btn_go_to_hq_view.png",
          "fallback_template": "btn_go_headquarters.png",
          "required": false
        }
      ]
    },
    {
      "action": "if_template_tap",
      "template": "btn_heal_icon.png",
      "required": false,
      "log_skip": "No Troops to Heal",
      "on_not_found": [
        {
          "action": "tap_template_or_template",
          "template": "btn_go_to_hq_view.png",
          "fallback_template": "btn_go_headquarters.png",
          "required": false
        }
      ]
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_heal_start.png",
      "required": false
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_heal_assist_from_allies.png",
      "required": false
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "tap_template_or_template",
      "template": "btn_go_to_hq_view.png",
      "fallback_template": "btn_go_headquarters.png",
      "required": false
    }
  ]
}
