{
  "name": "collect_radar",
  "actions": [
    {
      "action": "ensure_hq_view",
      "hq_btn": "btn_go_world.png",
      "world_btn": "btn_go_headquarters.png",
      "x_pct": 91.1,
      "y_pct": 95.6,
      "note": "Verify we are in HQ view before starting"
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_radar_collect_present.png",
      "required": false,
      "log_success": "Radar reward found \u00e2\u20ac\u201d collecting",
      "log_skip": "No radar collect button present \u00e2\u20ac\u201d skipping"
    },
    {
      "action": "wait",
      "seconds": 3.0
    },
    {
      "action": "tap_template_or_template",
      "template": "btn_laura_radar.png",
      "fallback_template": "btn_laura_alt.png",
      "required": false,
      "note": "Tap laura radar \u00e2\u20ac\u201d tries primary first, falls back to alternate if not found, skips if neither present"
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "repeat_if_template",
      "template": "btn_claim_all.png",
      "max_taps": 20,
      "delay": 2.0,
      "not_found_retries": 1,
      "log_success": "Claim All loop complete",
      "on_each": [
        {
          "action": "wait",
          "seconds": 2.0
        },
        {
          "action": "if_template_tap",
          "template": "btn_claim_all_recieved.png",
          "required": false,
          "note": "Dismiss reward received popup after each claim"
        },
        {
          "action": "wait",
          "seconds": 1.0
        }
      ]
    },
    {
      "action": "wait",
      "seconds": 2.0
    },
    {
      "action": "tap_template",
      "template": "btn_back.png",
      "timeout": 10,
      "required": false,
      "note": "Go back"
    }
  ]
}