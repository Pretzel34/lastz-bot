{
  "name": "identify_resources",
  "actions": [
    {
      "action": "if_template_tap",
      "template": "btn_warehouse.png",
      "required": true,
      "note": "Open warehouse — required. If not found, recenter and retry. If still missing, skip task."
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_statistics.png",
      "required": false
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "read_resource_priority",
      "anchor_template": "btn_resource_example.png",
      "note": "Screenshot the resource panel, rank by Total RSS ascending, save to logs/resource_priority.json"
    },
    {
      "action": "if_template_tap",
      "template": "btn_close.png",
      "required": false,
      "note": "Close panel if visible"
    },
    {
      "action": "wait",
      "seconds": 2.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_back_out_of_page.png",
      "required": false,
      "note": "Back out if visible"
    }
  ]
}
