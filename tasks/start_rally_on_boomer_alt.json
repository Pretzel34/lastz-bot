{
  "name": "start_rally_on_boomer_alt",
  "actions": [
    {
      "action": "rally_count_check",
      "note": "Abort if daily rally limit already reached"
    },
    {
      "action": "ensure_hq_view",
      "hq_btn": "btn_go_world.png",
      "world_btn": "btn_go_headquarters.png"
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_go_world.png",
      "required": false,
      "note": "Navigate from HQ to world view — skip if already in world"
    },
    {
      "action": "wait",
      "seconds": 4.0
    },
    {
      "action": "tap_template_or_zone",
      "template": "btn_search_lens_icon.png",
      "x_pct": 5.2,
      "y_pct": 80.7,
      "required": false
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_boomer.png",
      "fallback_template": "btn_frostbane_boomer.png",
      "required": false,
      "note": "Select Boomer category — tries btn_boomer.png first, falls back to btn_frostbane_boomer.png"
    },
    {
      "action": "wait",
      "seconds": 3.0
    },
    {
      "action": "adjust_boomer_level_from_one",
      "setting": "rally.boomer_level",
      "true_level_1_template": "btn_true_lvl_1.png",
      "plus_template": "btn_plus_boomer.png",
      "minus_template": "btn_subtract_boomer_lvl.png",
      "max_minus_taps": 50,
      "tap_delay": 0.7,
      "required": false,
      "note": "Checks for level 1 first, taps minus until btn_lvl_1_boomer.png confirmed, then taps plus (target-1) times"
    },
    {
      "action": "wait",
      "seconds": 2.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_search_boomer.png",
      "required": false,
      "note": "Search with the correct level now set"
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_team_up_boomer.png",
      "fallback_template": "btn_team_up_boomer_alt.png",
      "required": true
    },
    {
      "action": "wait",
      "seconds": 6.0
    },
    {
      "action": "if_template_tap",
      "template": "btn_march_on_boomer.png",
      "fallback_template": "btn_march_on_boomer_alt.png",
      "fuel_template": "btn_out_of_fuel.png",
      "required": false,
      "exhaust_rallies_if_not_found": true,
      "log_skip": "March not available — troops are busy, skipping rally attempt",
      "note": "If out of fuel, restore_fuel runs automatically and retries. If march still absent, troops are busy — abort."
    },
    {
      "action": "wait",
      "seconds": 6.0
    }
  ]
}
